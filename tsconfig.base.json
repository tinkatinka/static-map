{
  "compilerOptions": {
    "declaration": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "inlineSourceMap": false,
    "inlineSources": false,
    "isolatedModules": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "outDir": "./.build",
    "removeComments": true,
    "rootDirs": [
      "./src",
      "./tests"
    ],
    "skipLibCheck": true,
    "sourceMap": false,
    "strict": true,
    "target": "esnext",
    "types": [
      "node"
    ]
  },
  "exclude": [
    "node_modules"
  ]
}
